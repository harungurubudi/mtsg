// @Failure 400 {object} dto.ErrorResponse "Invalid refresh token"
// @Failure 401 {object} dto.ErrorResponse "Authentication failed"
// @Failure 500 {object} dto.ErrorResponse "Internal server error"
// @Security BearerAuth
// @Router /auth/refresh [post]
