# MTSG Application Environment Variables
# Copy this file to .env and modify the values as needed

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HTTP server port (default: 8080)
MTSG_SERVER_PORT=8080

# Server read timeout (default: 30s)
MTSG_SERVER_READ_TIMEOUT=30s

# Server write timeout (default: 30s)
MTSG_SERVER_WRITE_TIMEOUT=30s

# Server idle timeout (default: 60s)
MTSG_SERVER_IDLE_TIMEOUT=60s

# Application environment (default: development)
# Options: development, staging, production
MTSG_SERVER_ENVIRONMENT=development

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis server host (default: localhost)
MTSG_REDIS_HOST=localhost

# Redis server port (default: 6379)
MTSG_REDIS_PORT=6379

# Redis password (default: empty)
MTSG_REDIS_PASSWORD=

# Redis database number (default: 0)
MTSG_REDIS_DB=0

# Redis connection pool size (default: 10)
MTSG_REDIS_POOL_SIZE=10

# =============================================================================
# FUTURE CONFIGURATIONS
# =============================================================================

# Database configuration (to be added later)
# MTSG_DATABASE_HOST=localhost
# MTSG_DATABASE_PORT=5432
# MTSG_DATABASE_USERNAME=mtsg_user
# MTSG_DATABASE_PASSWORD=your_password_here
# MTSG_DATABASE_DATABASE=mtsg
# MTSG_DATABASE_SSL_MODE=disable

# JWT configuration (to be added later)
# MTSG_JWT_SECRET_KEY=your_jwt_secret_key_here
# MTSG_JWT_DURATION=24h
# MTSG_JWT_ISSUER=mtsg

# Logging configuration (to be added later)
# MTSG_LOG_LEVEL=info
# MTSG_LOG_FORMAT=json
# MTSG_LOG_OUTPUT=stdout 